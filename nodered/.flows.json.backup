    {
        "id": "b9913df8449ddd67",
        "type": "function",
        "z": "6ce586ae68324cf4",
        "name": "data generation",
        "func": "const now = new Date();\nmsg.payload = {\n    device_id: \"capteur-salle-tp-01\",\n    timestamp: now.toISOString(),\n    timestamp_unix: Math.floor(now.getTime() / 1000),\n    temperature: parseFloat((Math.random() * 10 + 18).toFixed(2)),\n    humidity: parseFloat((Math.random() * 40 + 40).toFixed(2)),\n    location: \"Salle TP Informatique\",\n    battery_level: parseFloat((Math.random() * 20 + 80).toFixed(1))\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 360,
        "y": 60,
        "wires": [
            [
                "224e3f39b8325730"
            ]
        ]
    },
